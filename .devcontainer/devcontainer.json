{
  "name": "Claude Terminal",
  "image": "mcr.microsoft.com/devcontainers/universal:2",
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": {
      "label": "Claude Terminal",
      "onAutoForward": "openBrowser",
      "protocol": "http"
    }
  },
  "containerEnv": {
    "CLAUDE_TERMINAL_TOKEN": "claude123",
    "WORK_DIR": "/workspaces/claude-terminal"
  },
  "postCreateCommand": "pip install fastapi uvicorn[standard] websockets pydantic && chmod +x /workspaces/claude-terminal/start.sh",
  "postStartCommand": "cd /workspaces/claude-terminal && bash start.sh",
  "customizations": {
    "vscode": {
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "files.exclude": {
          "**/__pycache__": true,
          "**/*.pyc": true
        }
      }
    }
  }
}
